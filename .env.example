# Sata — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Gemini API key (from Google AI Studio or Vertex AI)
LLM_API_KEY=your-gemini-api-key-here

# Model name to use for chat completions
LLM_CHAT_MODEL=gemini-2.0-flash

# OpenAI-compatible base URL for Gemini (NFR9)
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Embedding model for RAG (Phase 2 — used by ChromaDB/FAISS)
LLM_EMBEDDING_MODEL=gemini-embedding-001

# Target API under test (optional — can also be entered via UI)
TARGET_API_URL=https://your-api-under-test.example.com

# Auth credentials for the target API (optional — leave blank if not needed)
API_BEARER_TOKEN=
API_KEY=
