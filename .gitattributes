# Auto-detect text files and normalize line endings to LF on check-in
* text=auto eol=lf

# Explicitly declare text files
*.py    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.sh    text eol=lf
*.txt   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# Declare binary files (never diff or merge)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
