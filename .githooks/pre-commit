#!/bin/sh

# Run ruff lint and format check on staged Python files (fast, zero-install via uvx).
# Excludes tooling/AI directories that are not part of the application source.

staged_py=$(git diff --cached --name-only --diff-filter=ACM -- '*.py' \
    | grep -v -E '^(_bmad|\.agents|\.claude|\.cursor)/')

if [ -z "$staged_py" ]; then
    exit 0
fi

echo "pre-commit: running ruff on staged Python files..."

if ! printf '%s\n' "$staged_py" | xargs uvx ruff check --quiet; then
    echo ""
    echo "  Lint errors found. Fix them or run:"
    echo "    uvx ruff check --fix <file>"
    echo ""
    exit 1
fi

if ! printf '%s\n' "$staged_py" | xargs uvx ruff format --check --quiet; then
    echo ""
    echo "  Formatting issues found. Run:"
    echo "    uvx ruff format <file>"
    echo "  then re-stage the file."
    echo ""
    exit 1
fi

echo "pre-commit: ruff OK"
